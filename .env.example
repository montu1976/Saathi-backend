OPENAI_API_KEY=your_openai_key
ADMIN_KEY=change-me-admin-key

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# PUBLIC URL of your Saathi website (used in WhatsApp links).
# Production (real users, any network): https://your-app.onrender.com or your domain
# Local testing only: http://YOUR_PC_IP:3000 (same Wi-Fi as phone) — NOT for real launch
APP_URL=https://your-saathi-app.example.com

# Web push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
